# Mac backend configuration.

# DTN
DTN_NODE_ID=dtn://mac-ground.dtn/
DTN_SOCKET_PATH=/tmp/ud3tn.socket
DTN_MTCP_PORT=4224
ENABLE_DTN_BRIDGE=true

# API Server
API_HOST=0.0.0.0
API_PORT=8080

# Config Server — Pi connects here over Ethernet only
CONFIG_HOST=192.168.4.1
CONFIG_PORT=8765

# Frontend host visible to browsers on the network
FRONTEND_PUBLIC_HOST=100.110.162.30

# SQLite (repo `.run/` avoids readonly /tmp files from other users)
DB_PATH=../.run/dtn_testbed.db

# Rolling telemetry metrics
REALTIME_DEADLINE_MS=2000
METRICS_WINDOW_SIZE=100
