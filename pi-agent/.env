# Pi agent configuration.

# DTN
DTN_NODE_ID=dtn://pi-telemetry.dtn/
DTN_AGENT_TELEM=telemetry
DTN_AGENT_STATUS=status
DTN_DEST_NODE=dtn://mac-ground.dtn/
DTN_SOCKET_PATH=/tmp/ud3tn.socket
DTN_SOCKET_PATH_WIFI=/tmp/ud3tn.socket
DTN_SOCKET_PATH_LTE=/tmp/ud3tn-lte.socket
DTN_AAP2_SOCKET_PATH_WIFI=/tmp/ud3tn.aap2.socket
DTN_AAP2_SOCKET_PATH_LTE=/tmp/ud3tn-lte.aap2.socket
DTN_MTCP_PORT_WIFI=4224
DTN_MTCP_PORT_LTE=4225
DTN_BUNDLE_LIFETIME_S=3600
MAC_DTN_IP=4.tcp.ngrok.io
MAC_DTN_PORT=16748

# Management plane
MGMT_SERVER_IP=192.168.4.1
MGMT_SERVER_PORT=8765
MGMT_HEARTBEAT_S=5
MGMT_RECONNECT_S=10

# GPS
GPS_SERIAL_PORT=auto
GPS_BAUDRATE=115200
GPS_READ_INTERVAL_S=1.0

# Interfaces
WIFI_INTERFACE=auto
LTE_INTERFACE=auto
ETH_INTERFACE=auto
ETH_STATIC_IP=192.168.4.2

# Link manager
DEFAULT_LINK_MODE=auto
CONNECTIVITY_CHECK_S=5
FAILOVER_THRESHOLD=3

# Queue
MAX_QUEUE_SIZE=1024

# Identity
DEVICE_ID=pi-dtn-01
